{
  "ts.tsdk": "node_modules/typescript/lib",
  "ts.enablePromptUseWorkspaceTsdk": true,
  "ts.experimental.useTsgo": true,

  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },

  "ts.preferences.importModuleSpecifier": "non-relative",
  "js.preferences.importModuleSpecifier": "non-relative",
  "js.preferences.importModuleSpecifierEnding": "minimal",
  "ts.preferences.importModuleSpecifierEnding": "minimal",
  "ts.preferences.autoImportFileExcludePatterns": [
    "next/router.d.ts",
    "next/dist/client/router.d.ts",
    "lucide-react"
  ],
  "emmet.triggerExpansionOnTab": false,
  "emmet.showExpandedAbbreviation": "never",
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  }
}
